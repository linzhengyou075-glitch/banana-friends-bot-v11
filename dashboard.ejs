<!doctype html><html lang="zh-Hant"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>蕉個朋友後台</title><link rel="stylesheet" href="/css/admin.css"></head><body><header><h1>🍌〔蕉〕個朋友吧！Bot 後台</h1></header><main>
<section class="grid"><div class="card"><h2>會員</h2><b><%= users.length %></b></div><div class="card"><h2>商品</h2><b><%= items.length %></b></div><div class="card"><h2>狀態</h2><b>Online</b></div></section>
<section class="card"><h2>⚙️ 系統設定</h2><form method="post" action="/admin/settings"><label>後台密碼<input name="adminPassword" value="<%= settings.adminPassword %>"></label><label>群規<textarea name="groupRules"><%= settings.groupRules %></textarea></label><label>歡迎訊息<textarea name="welcome"><%= settings.welcome %></textarea></label><label>公告<textarea name="announcement"><%= settings.announcement %></textarea></label><label>聊天EXP<input name="chatExp" value="<%= settings.chatExp %>"></label><label>簽到EXP<input name="signExp" value="<%= settings.signExp %>"></label><label>簽到香蕉幣<input name="signCoins" value="<%= settings.signCoins %>"></label><button>儲存設定</button></form></section>
<section class="card"><h2>🎁 新增商店商品</h2><form method="post" action="/admin/shop"><input name="category" placeholder="分類：🏅稱號"><input name="name" placeholder="商品名稱"><input name="price" placeholder="價格"><button>新增</button></form><ul><% items.forEach(i=>{ %><li><%= i.category %>｜<%= i.name %>｜<%= i.price %>幣</li><% }) %></ul></section>
<section class="card"><h2>👤 會員管理</h2><table><tr><th>名稱</th><th>EXP</th><th>幣</th><th>簽到</th></tr><% users.forEach(u=>{ %><tr><td><%= u.name %></td><td><%= u.exp %></td><td><%= u.coins %></td><td><%= u.signDays %></td></tr><% }) %></table></section>
</main></body></html>
